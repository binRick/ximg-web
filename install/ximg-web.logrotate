__REPO__/logs/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    sharedscripts
    postrotate
        docker compose -f __REPO__/compose.yaml exec -T nginx nginx -s reopen 2>/dev/null || true
        curl -sf http://localhost:3000/map-harvest > /dev/null 2>&1 || true
    endscript
}
